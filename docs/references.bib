% OpenLithoHub — bibliography snapshot
%
% This file is the canonical citation source for the OpenLithoHub
% codebase, docs, and submissions. Per playbook §5.2, we snapshot bibs
% into the repository (rather than chase live arXiv/DOI fetches) so the
% build is reproducible offline and the cited keys cannot drift under
% upstream metadata edits.
%
% Adding an entry:
%   1. Use the citation key style ``FirstAuthor<YEAR>_ShortTopic``
%      (e.g. ``Yang2023_LithoBench``). Inline mentions in code/docstrings
%      should match this key verbatim so grep finds both sides.
%   2. Include arXiv ID and DOI when both exist; arXiv tends to be the
%      stable URL, DOI the publisher-of-record.
%   3. Append a ``note = {...}`` summarising why this paper is cited in
%      OpenLithoHub — future maintainers should be able to audit without
%      reading the paper.
%
% Last verified: 2026-05-22.

@inproceedings{Yang2023_LithoBench,
  author    = {Zheng, Su and Yang, Haoyu and Yu, Bei and Pan, David Z. and Wong, Martin D. F.},
  title     = {{LithoBench}: Benchmarking {AI} Computational Lithography for Semiconductor Manufacturing},
  booktitle = {Advances in Neural Information Processing Systems (NeurIPS)},
  year      = {2023},
  eprint    = {2305.04345},
  archivePrefix = {arXiv},
  url       = {https://arxiv.org/abs/2305.04345},
  note      = {Reference benchmark and SOCS (24-kernel) Hopkins parameters used by HopkinsSim; Table III defines academic OPC printability as L2 + PVB on the simulated wafer image, which we mirror in the leaderboard schema (forward-sim gate).}
}

